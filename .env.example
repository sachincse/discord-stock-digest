# ---- Discord (Path A: official bot, added by a server owner/admin) ----
# Create at https://discord.com/developers/applications  ->  Bot -> Reset Token
# Enable "Message Content Intent" toggle on the Bot page (free, instant while
# the server has < 10,000 users).
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=            # right-click the channel -> Copy Channel ID (Developer Mode on)

# ---- Google Gemini (free tier via Google AI Studio) ----
# Get a key at https://aistudio.google.com/apikey  (keep billing DISABLED for the free tier)
GEMINI_API_KEY=

# ---- Reporting (all optional; file output always works) ----
# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Post the digest back into a Discord channel via an incoming webhook
DISCORD_WEBHOOK_URL=
